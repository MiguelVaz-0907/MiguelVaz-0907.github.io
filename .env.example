# Modo PIX: static (padrão, QR gerado no browser) | dynamic (cobrança Mercado Pago + webhook)
# VITE_PIX_MODE=static

# --- PIX estático (VITE_PIX_MODE=static ou omitido) ---
# Chave: e-mail em minúsculas | CPF/CNPJ só números | telefone: pode usar DDD+número (ex.: 91987654321) ou +5511987654321 | chave aleatória UUID
# Nome e cidade: cidade até 15 caracteres no padrão PIX (ex.: BELEM). Reinicie o npm run dev após alterar.
VITE_PIX_KEY=
VITE_PIX_MERCHANT_NAME=
VITE_PIX_MERCHANT_CITY=

# Supabase (site + PIX dinâmico)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- PIX dinâmico (VITE_PIX_MODE=dynamic) ---
# 1) Corra supabase/migrations/001 e 003 e 004 no painel SQL.
# 2) Mercado Pago → Developers → Credenciais: Production Access Token (ou Token de teste).
# 3) supabase secrets set MERCADOPAGO_ACCESS_TOKEN=APP_USR_... MERCADOPAGO_PAYER_EMAIL=noivos@example.com
#    MERCADOPAGO_PAYER_EMAIL: e-mail qualquer válido pedido pela API ao criar o pagamento (ex.: conta dos noivos).
#    Opcional: MERCADOPAGO_WEBHOOK_TOKEN=segredo_url | Mercado Livre permite URL tipo .../mercadopago-webhook?token=segredo
# 4) Deploy: supabase functions deploy create-pix-charge
#           supabase functions deploy mercadopago-webhook
# 5) MP → sua aplicação → Webhooks: URL https://<ref>.supabase.co/functions/v1/mercadopago-webhook
#    (Se usou MERCADOPAGO_WEBHOOK_TOKEN: acrescente ?token=... à URL configurada.)
